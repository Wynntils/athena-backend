                                            "type": "integer"
                                        }
                                    ],
                                    "minItems": 2,
                                    "maxItems": 2,
                                    "additionalItems": false
                                },
                                "end": {
                                    "type": "array",
                                    "prefixItems": [
                                        {
                                            "type": "integer"
                                        },
                                        {
                                            "type": "integer"
                                        }
                                    ],
                                    "minItems": 2,
                                    "maxItems": 2,
                                    "additionalItems": false
                                }
                            },
                            "required": [
                                "start",
                                "end"
                            ]
