                                "schema": {
                                    "$ref": "#/components/schemas/AuthResponseResource"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Notifications::log('<@&980223126619176960>', \"Unknown Profile for `{$request->validated('username')}`\", \"```json\\n\" . json_encode($profile, JSON_PRETTY_PRINT) . '```');",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "enum": [
                                                "The provided username or key is invalid"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "",
