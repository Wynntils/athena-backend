        "/version/latest/{stream}": {
            "get": {
                "operationId": "version.latest",
                "summary": "Get the latest release for a stream",
                "tags": [
                    "Version"
                ],
                "parameters": [
                    {
                        "name": "stream",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`VersionResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/VersionResource"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "",
