                                        "string",
                                        "null"
                                    ]
                                },
                                "prefix": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },
                                "color": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                }
                            },
                            "required": [
                                "name",
                                "prefix",
                                "color"
